<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="tests">
	<groups>

		<run>
			<include name="Error handling"></include>
		</run>
	</groups>
	<test thread-count="5" name="Submit order">
		<classes>
			<class name="jovicakuresevic.tests.SubmitOrderTest" />
		</classes>
	</test>
	<test thread-count="5" name="Error Validations tests">
		<classes>
			<class name="jovicakuresevic.tests.ErrorValidations" />
		</classes>
	</test>
</suite> 
